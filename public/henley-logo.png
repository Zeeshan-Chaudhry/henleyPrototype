}</style><style class="wpcode-css-snippet">/* Hero H1 — matches original H2 styles exactly (font size/appearance unchanged) */
.wpo-hero-slider .slide-title h1,
.static-hero .slide-title h1,
.wpo-hero-slider-s2 .slide-title h1 {
  font-size: 100px;
  font-weight: 500;
  line-height: 60px;
  margin: 10px 0px 20px;
  color: rgb(255, 255, 255);
}

.static-hero .slide-title h1 {
  color: rgb(13, 8, 69);
  font-weight: 600;
  font-size: 80px;
  line-height: 116px;
}

.elementor-16 .elementor-element.elementor-element-21a78b4 .static-hero .slide-title h1 {
  font-family: Jost, sans-serif;
  color: rgb(0, 0, 0);
}

/* "Care" span — restore original golden yellow color */
.static-hero .slide-title h1 span {
  color: rgb(202, 171, 6);
}

@media (max-width: 1199px) {
  .wpo-hero-slider .slide-title h1,
  .static-hero .slide-title h1,
  .wpo-hero-slider-s2 .slide-title h1 {
    font-size: 3.33333rem;
  }
}

@media (max-width: 991px) {
  .wpo-hero-slider .slide-title h1,
  .static-hero .slide-title h1,
  .wpo-hero-slider-s2 .slide-title h1 {
    font-size: 2.66667rem;
    line-height: 55px;
    margin-bottom: 20px;
  }
}

@media (max-width: 767px) {
  .wpo-hero-slider .slide-title h1,
  .static-hero .slide-title h1,
  .wpo-hero-slider-s2 .slide-title h1 {
    font-size: 2rem;
    line-height: 1.3;
  }
}

/* Decorative "Unique" text — restore original large outline appearance on p tag */
.static-hero .slide-visible-text p {
  font-style: normal;
  font-weight: 900;
  font-size: 200px;
  line-height: 289px;
  -webkit-text-fill-color: rgb(250, 250, 250);
  -webkit-text-stroke: 1px rgb(225, 223, 213);
  position: relative;
  bottom: -132px;
  margin: 0;
}

@media (max-width: 1600px) {
  .static-hero .slide-visible-text p { font-size: 140px; bottom: -126px; }
}

@media (max-width: 1300px) {
  .static-hero .slide-visible-text p { font-size: 120px; }
}

@media (max-width: 1200px) {
  .static-hero .slide-visible-text p { font-size: 100px; bottom: -20px; line-height: 120px; }
}

@media (max-width: 991px) {
  .static-hero .slide-visible-text p { bottom: 0px; }
}

@media (max-width: 767px) {
  .static-hero .slide-visible-text p { font-size: 72px; line-height: 54px; }
}</style><style class="wpcode-css-snippet">.hfe-post-card a > img {
  width: 100%;
  aspect-ratio: 2 / 1;
  object-fit: cover;
  display: block;
